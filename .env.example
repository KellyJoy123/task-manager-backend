# ==========================================
# CONFIGURACIÓN DE MONGODB ATLAS
# ==========================================
# Obtén tu URL en: MongoDB Atlas → Clusters → Connect → Connect your application
# Reemplaza <username> y <password> con tus credenciales
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/taskmanager?retryWrites=true&w=majority&appName=Cluster0

# ==========================================
# CONFIGURACIÓN DEL SERVIDOR
# ==========================================
PORT=3001

# ==========================================
# CONFIGURACIÓN DE JWT (Si usas autenticación)
# ==========================================
# JWT_SECRET=tu-secreto-aqui
# JWT_EXPIRES_IN=7d